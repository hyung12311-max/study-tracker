{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/index.js": {
      "includeFiles": "server/api/**"
    },
    "api/[...path].js": {
      "includeFiles": "server/api/**"
    },
    "api/reward_milestones.js": {
      "includeFiles": "server/api/**"
    },
    "api/completion_notifications.js": {
      "includeFiles": "server/api/**"
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api?path=:path*"
    }
  ]
}
